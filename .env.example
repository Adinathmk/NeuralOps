# ============================================================
# NeuralOps — Monorepo Environment Variables Example
# ============================================================
# Instructions:
#   1. Copy this file to .env.docker:
#      cp .env.example .env.docker
#   2. Fill in your real keys, secrets, and credentials.
#   3. NEVER commit .env.docker to Git.
# ============================================================

# ── Django Core ─────────────────────────────────────────────
DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production-12345
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database (PostgreSQL — DB-1: Django) ────────────────────
DATABASE_URL=postgresql://neuralops:neuralops_password@django_db:5432/neuralops_db
DJANGO_DB_HOST=django_db
DJANGO_DB_PORT=5432
DJANGO_DB_USER=neuralops
DJANGO_DB_PASSWORD=neuralops_password
DJANGO_DB_NAME=neuralops_db
# Aliases used inside Django's entrypoint wait script
DB_HOST=django_db
DB_PORT=5432
DB_USER=neuralops
DB_PASSWORD=neuralops_password
DB_NAME=neuralops_db

# ── Database (PostgreSQL — DB-2: FastAPI) ───────────────────
FASTAPI_DB_NAME=neuralops_fastapi_db
FASTAPI_DB_USER=neuralops_fastapi
FASTAPI_DB_PASSWORD=fastapi_password

# ── Shared Redis (Cache, Sessions & Task Queue Broker) ──────
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT Authentication (RS256 Signature Keys) ───────────────
# Note: FastAPI (Service 2) reads the JWT_PUBLIC_KEY to verify tokens
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_RSA_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_RSA_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS Gateway Tuning ──────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ── Gunicorn Tuning ─────────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ── Email System (AWS SES SMTP) ──────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.ap-south-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=YOUR_SES_SMTP_USERNAME_HERE
EMAIL_HOST_PASSWORD=YOUR_SES_SMTP_PASSWORD_HERE
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Frontend Routing & OAuth URLs ────────────────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000/dashboard
FRONTEND_OAUTH_ERROR_URL=http://localhost:3000/login

# ── Google Authentication ────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── GitHub Integration ───────────────────────────────────────
GITHUB_OAUTH_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_OAUTH_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/github/callback

# ── MinIO Object Storage (S3-Compatible) ─────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadminpassword
AWS_REGION_NAME=us-east-1
AWS_S3_BUCKET_NAME=neuralops-artifacts
AWS_S3_SIGNED_URL_EXPIRY=900
AWS_S3_ENDPOINT_URL=http://minio:9000

# ── Symmetric Encryption Key (For Encrypting Integration Secrets)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY=L6TdigR82nNTKUvXsuuxkOJ1Cuo2aBpncHW1WRI72ec=

# ── Kafka Event Streaming ────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLUSTER_ID=RdEoWBwUQyuyHQvv8SfHSA
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── Debezium CDC Connectors ───────────────────────────────────
DEBEZIUM_URL=http://debezium:8083

# ── Elasticsearch Engine ──────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# Razorpay
RAZORPAY_KEY_ID=rzp_test_example
RAZORPAY_KEY_SECRET=example_secret
RAZORPAY_WEBHOOK_SECRET=example_webhook_secret

# -- GitHub App Auth --------------------------------------------------------
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_WEBHOOK_SECRET="your_webhook_secret_here"

