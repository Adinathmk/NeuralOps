# ============================================================
# NeuralOps — Environment Variables Example
# ============================================================
# Copy this file to .env.docker and fill in your real values:
#   cp .env.example .env.docker
# ============================================================

# ── Django Core ─────────────────────────────────────────────
DEBUG=False
SECRET_KEY=CHANGE_ME_generate_with_python_-c_"import_secrets;print(secrets.token_hex(50))"
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,yourdomain.com

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://neuralops:YOUR_DB_PASSWORD@db:5432/neuralops_db
DB_HOST=db
DB_PORT=5432
DB_USER=neuralops
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD
DB_NAME=neuralops_db

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_another_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ── Gunicorn ─────────────────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ── Email (AWS SES SMTP) ─────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.ap-south-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=YOUR_SES_SMTP_USERNAME
EMAIL_HOST_PASSWORD=YOUR_SES_SMTP_PASSWORD
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Frontend URLs ────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000/dashboard
FRONTEND_OAUTH_ERROR_URL=http://localhost:3000/login

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── GitHub OAuth ─────────────────────────────────────────────
GITHUB_OAUTH_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_OAUTH_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/github/callback
