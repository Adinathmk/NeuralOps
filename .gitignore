# ============================================================
# NeuralOps — Git Ignore Configuration
# ============================================================

# ── Python Cache & Compiled Files ────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ── Virtual Environments ──────────────────────────────────────
venv/
env/
ENV/
fvenv/
.venv/
.env/

# ── Nox Automation & Testing Cache ────────────────────────────
.nox/
.pytest_cache/
.coverage
htmlcov/

# ── Application State, Statics & Logs ─────────────────────────
logs/
*.log
staticfiles/
mediafiles/
media/
django/staticfiles/
django/mediafiles/
django/logs/
fastapi/htmlcov/
django/htmlcov/

# ── Databases (Local Development) ─────────────────────────────
*.sqlite3
*.db
db.sqlite3

# ── Environment Secrets (Never Commit Real Credentials) ────────
.env
.env.local
.env*.local
.env.docker

# ── IDEs, Editors & OS Files ──────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
