# ============================================================
# NeuralOps — Git Ignore Configuration
# ============================================================

# ── Python Cache & Compiled Files ────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
celerybeat-schedule*

# ── Virtual Environments ──────────────────────────────────────
venv/
env/
ENV/
fvenv/
.venv/
.env/

# ── Nox Automation & Testing Cache ────────────────────────────
.nox/
.tox/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── Application State, Statics & Logs ─────────────────────────
logs/
*.log
*_logs.txt
staticfiles/
mediafiles/
media/
django/staticfiles/
django/mediafiles/
django/logs/
fastapi/htmlcov/
django/htmlcov/

# ── Databases (Local Development) ─────────────────────────────
*.sqlite3
*.sqlite3-journal
*.db
db.sqlite3

# ── Environment Secrets & Configs ─────────────────────────────
.env
.env.local
.env*.local
.env.docker
*.pem
*.key
docker-compose.override.yml

# ── IDEs, Editors & OS Files ──────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── AWS Lambda Artifacts ──────────────────────────────────────
*.zip
_stage_*/
package/
deps/

# Ignore pip-installed dependencies inside lambda source folders
# (installed by build scripts for packaging, not source code)
lambdas/lambda-push-dispatch/*/
lambdas/lambda-push-router/*/
lambdas/*/*.dist-info/
lambdas/*/bin/
